{
  "_meta": {
    "version": "1.0",
    "description": "Wireframe component registry. Each component defines a section with layout, spacing, color, and child structure. Variants allow theme switching. This file is dynamic — new components are added after user approval."
  },

  "_constants": {
    "colors": {
      "light": ["#FFFFFF", "#F5F5F5", "#DFDFDF"],
      "dark": ["#121212", "#2C2C2C", "#464646"],
      "text": {
        "onLight": "#000000",
        "onDark": "#FFFFFF"
      },
      "note": "Only achromatic values. Can shade between defined stops but never introduce chromatic color. No blue, green, orange, etc."
    },
    "fonts": {
      "heading": "Geist",
      "body": "Geist",
      "mono": "Geist Mono",
      "usage": {
        "headings": "Geist",
        "bodyText": "Geist",
        "eyebrow": "Geist Mono",
        "buttons": "Geist Mono",
        "labels": "Geist Mono",
        "code": "Geist Mono"
      }
    },
    "imagePlaceholder": {
      "onLight": {
        "background": "#DFDFDF",
        "border": "1px dashed #DFDFDF",
        "labelColor": "#464646"
      },
      "onDark": {
        "background": "#464646",
        "border": "1px dashed #464646",
        "labelColor": "#DFDFDF"
      },
      "label": "Centered dimension text, e.g. '1200×300' or '48×48'",
      "labelFont": "Geist Mono",
      "note": "Image placeholders must always have a visible fill that contrasts with the section background. Use onLight when the parent section uses a light variant, onDark when the parent uses a dark variant."
    },
    "rules": [
      "Never use shadow",
      "Never use effects or texture",
      "Never use chromatic color",
      "Text is always #FFFFFF or #000000 depending on background"
    ]
  },

  "nav-bar": {
